# ============================================================
# Evergreen Love ERP — Variables de entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env a git.
# ============================================================

# --- Bootstrap del primer administrador (solo necesario en la instalación inicial) ---
# Una vez que el primer admin existe en la BD, estas variables pueden eliminarse.
ADMIN_EMAIL=admin@evergreenlove.com
ADMIN_PASSWORD=cambia-esta-contrasena

# --- JWT (obligatorio en producción) ---
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=cambia-esta-clave-secreta-minimo-32-caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- CORS (dominios permitidos, separados por coma) ---
# En producción usa solo tu dominio real.
ALLOWED_ORIGINS=https://evergreen-love-erp.onrender.com,http://localhost:8000,http://127.0.0.1:8000

# --- Notificaciones Telegram (opcional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email / SMTP (opcional, para envío de recibos) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
